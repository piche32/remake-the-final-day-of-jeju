# Unity 6 gitignore template
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/

# AssetStoreTools
[Aa]ssets/AssetStoreTools*

# Autogenerated MSVC project files
[Vv]isualStudio/
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svclog
*.pdb
*.mdb
*.opendb
*.db
sysinfo.txt

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
CrashReport*

# macOS
.DS_Store

# IDEs
.idea/
.vsCode/
.history/
.ionide/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-scripts.json
*.code-workspace

# Unity 6 / URP / HDRP
[Uu]serSettings/
*.pid
*.bin
*.db-journal

# Assets/Plugins/Editor/JetBrains
/Assets/Plugins/Editor/JetBrains*

# PlasticSCM
.plastic/
